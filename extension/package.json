{
  "name": "comprendo",
  "displayName": "Comprendo",
  "description": "Understand your codebase with AI-powered explanations, quizzes, and dependency graphs.",
  "version": "0.1.0",
  "publisher": "farillarad",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "comprendo.explainThis",
        "title": "Comprendo: Explain This"
      },
      {
        "command": "comprendo.openBrainTree",
        "title": "Comprendo: Open Brain Tree"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "comprendo.explainThis",
          "when": "editorHasSelection",
          "group": "comprendo@1"
        }
      ]
    },
    "configuration": {
      "title": "Comprendo",
      "properties": {
        "comprendo.apiKey": {
          "type": "string",
          "default": "",
          "description": "Your Claude API key (get one at console.anthropic.com)",
          "markdownDescription": "Your Claude API key. Get one at [console.anthropic.com](https://console.anthropic.com)."
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "comprendo-sidebar",
          "title": "Comprendo",
          "icon": "$(book)"
        }
      ]
    },
    "views": {
      "comprendo-sidebar": [
        {
          "type": "webview",
          "id": "comprendo.sidebarView",
          "name": "File Insight"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.36.3"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0"
  }
}
