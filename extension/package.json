{
  "name": "comprendo",
  "displayName": "Comprendo",
  "description": "Understand your codebase with AI-powered dependency graphs, file explanations, and quizzes.",
  "version": "0.1.0",
  "publisher": "farillarad",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "comprendo.openBrainTree",
        "title": "Comprendo: Open Brain Tree"
      },
      {
        "command": "comprendo.startBackend",
        "title": "Comprendo: Start Backend Server"
      }
    ],
    "configuration": {
      "title": "Comprendo",
      "properties": {
        "comprendo.apiKey": {
          "type": "string",
          "default": "",
          "description": "Your Claude API key (get one at console.anthropic.com)",
          "markdownDescription": "Your Claude API key. Get one at [console.anthropic.com](https://console.anthropic.com)."
        },
        "comprendo.backendUrl": {
          "type": "string",
          "default": "http://localhost:8000",
          "description": "URL of the Comprendo FastAPI backend"
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "comprendo-sidebar",
          "title": "Comprendo",
          "icon": "$(book)"
        }
      ]
    },
    "views": {
      "comprendo-sidebar": [
        {
          "type": "webview",
          "id": "comprendo.sidebarView",
          "name": "File Insight"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0"
  }
}
